function scr_easename(ease){
	if(ease==0) return ("l");
	else if(ease==1) return ("o^2");
	else if(ease==2) return ("i^2");
	else if(ease==3) return ("so");
	else if(ease==4) return ("si");
	else if(ease==5) return ("oo");
	else if(ease==6) return ("oi");
	else if(ease==7) return ("o^3");
	else if(ease==8) return ("i^3");
	else return ("自定义");
}